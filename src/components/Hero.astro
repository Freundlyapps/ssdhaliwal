---
interface Props {
  lang?: 'en' | 'de';
}

const { lang = 'en' } = Astro.props;

const hero = {
  en: {
    greeting: 'Hi, I\'m',
    name: 'Sarabjit Singh Dhaliwal',
    title: 'I help small businesses get online',
    description: 'Websites, booking systems, online ordering & AI automation for any small business. Based in Austria, available worldwide. Affordable, fast, DSGVO-compliant.',
    ctaPrimary: 'Free Consultation',
    ctaSecondary: 'View Services',
    available: 'Available for new projects',
    trustLine: 'Austria-based — Available worldwide',
    startingFrom: 'Websites from €290',
  },
  de: {
    greeting: 'Hallo, ich bin',
    name: 'Sarabjit Singh Dhaliwal',
    title: 'Ich helfe Kleinunternehmen online zu gehen',
    description: 'Websites, Buchungssysteme, Online-Bestellung & KI-Automatisierung für jedes Kleinunternehmen. In Österreich ansässig, weltweit verfügbar. Leistbar, schnell, DSGVO-konform.',
    ctaPrimary: 'Kostenloses Erstgespräch',
    ctaSecondary: 'Leistungen ansehen',
    available: 'Verfügbar für neue Projekte',
    trustLine: 'In Österreich ansässig — Weltweit verfügbar',
    startingFrom: 'Websites ab €290',
  },
};

const t = hero[lang];
const isGerman = lang === 'de';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-accent/10 to-primary/20 dark:from-primary/10 dark:via-accent/5 dark:to-primary/10"></div>

  <!-- Animated gradient blobs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/30 dark:bg-primary/20 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent/30 dark:bg-accent/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Photo/Avatar -->
      <div class="flex justify-center lg:justify-start order-1 lg:order-1">
        <div class="relative animate-fade-in">
          <!-- Avatar -->
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-full bg-gradient-to-br from-primary to-accent p-1.5 shadow-2xl hover:scale-105 transition-transform duration-500">
            <div class="w-full h-full rounded-full bg-gray-200 dark:bg-gray-800 flex items-center justify-center overflow-hidden">
              <img src="/images/avatar.jpg" alt="Sarabjit Singh Dhaliwal" class="w-full h-full object-cover" />
            </div>
          </div>

          <!-- Status badge -->
          <div class="absolute -bottom-4 -right-4 bg-green-500 text-white px-4 py-2 rounded-full text-sm font-semibold shadow-lg flex items-center animate-bounce">
            <span class="w-2 h-2 bg-white rounded-full mr-2 animate-pulse"></span>
            {t.available}
          </div>
        </div>
      </div>

      <!-- Right: Text Content -->
      <div class="text-center lg:text-left order-2 lg:order-2 animate-slide-up">
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-2">
          {t.greeting}
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-4">
          {t.name}
        </h1>
        <h2 class="text-2xl md:text-3xl font-semibold text-primary mb-6">
          {t.title}
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 max-w-xl mx-auto lg:mx-0">
          {t.description}
        </p>

        <!-- Trust signals instead of tech badges -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-3 mb-8">
          <span class="inline-flex items-center px-4 py-2 bg-green-100 dark:bg-green-900/30 rounded-lg text-sm font-medium text-green-700 dark:text-green-300">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {t.startingFrom}
          </span>
          <span class="inline-flex items-center px-4 py-2 bg-blue-100 dark:bg-blue-900/30 rounded-lg text-sm font-medium text-blue-700 dark:text-blue-300">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            DSGVO
          </span>
          <span class="inline-flex items-center px-4 py-2 bg-gray-100 dark:bg-gray-800 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {t.trustLine}
          </span>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href={isGerman ? '/de#contact' : '#contact'}
            class="inline-flex items-center px-8 py-4 bg-primary hover:bg-blue-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-2xl hover:scale-105 transition-all duration-300 text-center group"
          >
            {t.ctaPrimary}
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={isGerman ? '/de#services' : '#services'}
            class="inline-flex items-center px-8 py-4 border-2 border-primary text-primary dark:text-primary-light hover:bg-primary hover:text-white hover:scale-105 font-semibold rounded-lg shadow-md hover:shadow-xl transition-all duration-300 text-center group"
          >
            {t.ctaSecondary}
            <svg class="w-5 h-5 ml-2 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <a href="#about" class="text-gray-400 hover:text-primary transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
