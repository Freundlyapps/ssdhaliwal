---
interface Props {
  lang?: 'en' | 'de';
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    sectionTag: 'Demos',
    heading: 'See It In Action',
    subheading: 'Watch quick demos of my projects and see how they work.',
    watchBtn: 'Watch Demo',
  },
  de: {
    sectionTag: 'Demos',
    heading: 'In Aktion sehen',
    subheading: 'Kurze Demos meiner Projekte ansehen und erfahren, wie sie funktionieren.',
    watchBtn: 'Demo ansehen',
  },
};

const t = content[lang];

// Video demos - update these with your actual YouTube video IDs
const videos = [
  {
    id: 'VIDEO_ID_1',
    title: { en: 'PicShifter Demo', de: 'PicShifter Demo' },
    description: {
      en: 'See how PicShifter transforms images with AI-powered batch processing.',
      de: 'Sehen Sie, wie PicShifter Bilder mit KI-gestützter Stapelverarbeitung transformiert.',
    },
  },
  {
    id: 'VIDEO_ID_2',
    title: { en: 'Writola Demo', de: 'Writola Demo' },
    description: {
      en: 'Watch Writola generate and schedule social media content automatically.',
      de: 'Sehen Sie, wie Writola Social-Media-Inhalte automatisch erstellt und plant.',
    },
  },
  {
    id: 'VIDEO_ID_3',
    title: { en: 'AI Automation Workflow', de: 'KI-Automatisierungs-Workflow' },
    description: {
      en: 'A walkthrough of a custom AI automation pipeline built for a client.',
      de: 'Ein Rundgang durch eine individuelle KI-Automatisierungspipeline für einen Kunden.',
    },
  },
];
---

<section id="demos" class="py-20 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary dark:text-primary-light rounded-full text-sm font-semibold mb-4">
        {t.sectionTag}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {t.heading}
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        {t.subheading}
      </p>
    </div>

    <!-- Video Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {videos.map((video) => (
        <div class="reveal group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
          <!-- Video Thumbnail / Embed -->
          <div class="relative aspect-video bg-gray-200 dark:bg-gray-700 overflow-hidden">
            <iframe
              class="w-full h-full"
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title[lang]}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

          <!-- Video Info -->
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
              {video.title[lang]}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">
              {video.description[lang]}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
