---
interface Props {
  lang?: 'en' | 'de';
}

const { lang = 'en' } = Astro.props;

const about = {
  en: {
    sectionTitle: 'About Me',
    sectionSubtitle: 'Why small businesses trust me with their online presence',
    journey: 'My Story',
    journeyText: 'I started by building tools for content creators. Then I noticed something: local businesses — restaurants, barbers, pet services — all need digital solutions but can\'t afford agency prices. So I focused on what matters: practical, affordable websites and systems that actually bring in customers.',
    whatIDo: 'What You Get',
    whatIDoText1: 'I don\'t just build websites — I help you get more customers. Online ordering that works. Booking systems that save you phone calls. Websites that show up on Google.',
    whatIDoText2: 'Everything DSGVO-compliant, in German and English. Available for meetings in Austria and remote work worldwide.',
    philosophy: 'My Promise',
    philosophyText: '"Fair prices, real results." No hidden costs, no 6-month timelines. Your website ready in days, not months.',
    whyMe: 'Why Work With Me',
    reason1Title: 'Affordable',
    reason1Text: 'Websites from €290. No agency markups, no surprise invoices.',
    reason2Title: 'Fast Delivery',
    reason2Text: 'Most projects completed within 1–2 weeks. You don\'t wait months.',
    reason3Title: 'Local & Personal',
    reason3Text: 'Based in Austria. You talk directly to me — no middlemen, no support tickets.',
    reason4Title: 'DSGVO Compliant',
    reason4Text: 'Impressum, Datenschutz, cookie consent — all legal requirements handled.',
    reason5Title: 'Mobile-First',
    reason5Text: '80% of your customers search on their phone. Every site I build works perfectly on mobile.',
    reason6Title: 'Ongoing Support',
    reason6Text: 'Questions after launch? I\'m here. No expensive maintenance contracts required.',
  },
  de: {
    sectionTitle: 'Über mich',
    sectionSubtitle: 'Warum Kleinunternehmen mir ihre Online-Präsenz anvertrauen',
    journey: 'Meine Geschichte',
    journeyText: 'Ich habe damit angefangen, Tools für Content Creator zu entwickeln. Dann ist mir aufgefallen: Lokale Unternehmen — Restaurants, Friseure, Tierdienste — brauchen alle digitale Lösungen, können sich aber keine Agenturpreise leisten. Also habe ich mich auf das konzentriert, was zählt: praktische, leistbare Websites und Systeme, die tatsächlich Kunden bringen.',
    whatIDo: 'Was Sie bekommen',
    whatIDoText1: 'Ich baue nicht nur Websites — ich helfe Ihnen, mehr Kunden zu gewinnen. Online-Bestellung die funktioniert. Buchungssysteme, die Ihnen Anrufe ersparen. Websites, die bei Google gefunden werden.',
    whatIDoText2: 'Alles DSGVO-konform, auf Deutsch und Englisch. Verfügbar für Termine in Österreich und Remote-Arbeit weltweit.',
    philosophy: 'Mein Versprechen',
    philosophyText: '"Faire Preise, echte Ergebnisse." Keine versteckten Kosten, keine 6-Monats-Timelines. Ihre Website in Tagen fertig, nicht Monaten.',
    whyMe: 'Warum mit mir arbeiten',
    reason1Title: 'Leistbar',
    reason1Text: 'Websites ab €290. Keine Agentur-Aufschläge, keine Überraschungsrechnungen.',
    reason2Title: 'Schnelle Lieferung',
    reason2Text: 'Die meisten Projekte in 1–2 Wochen fertig. Sie warten keine Monate.',
    reason3Title: 'Lokal & Persönlich',
    reason3Text: 'In Österreich ansässig. Sie sprechen direkt mit mir — keine Mittelsmänner, keine Support-Tickets.',
    reason4Title: 'DSGVO-konform',
    reason4Text: 'Impressum, Datenschutz, Cookie-Consent — alle rechtlichen Anforderungen erledigt.',
    reason5Title: 'Mobile-First',
    reason5Text: '80% Ihrer Kunden suchen am Handy. Jede Website, die ich baue, funktioniert perfekt mobil.',
    reason6Title: 'Laufender Support',
    reason6Text: 'Fragen nach dem Launch? Ich bin da. Keine teuren Wartungsverträge nötig.',
  },
};

const t = about[lang];
---

<section id="about" class="py-20 bg-white dark:bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {t.sectionTitle}
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-400">
        {t.sectionSubtitle}
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: Story -->
      <div class="space-y-8">
        <div class="reveal" style="transition-delay: 0.1s;">
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
            <span class="w-10 h-10 flex items-center justify-center mr-3 text-primary">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </span>
            {t.journey}
          </h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            {t.journeyText}
          </p>
        </div>

        <div class="reveal" style="transition-delay: 0.2s;">
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
            <span class="w-10 h-10 flex items-center justify-center mr-3 text-accent">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </span>
            {t.whatIDo}
          </h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-4">
            {t.whatIDoText1}
          </p>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
            {t.whatIDoText2}
          </p>
        </div>

        <div class="reveal" style="transition-delay: 0.3s;">
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
            <span class="w-10 h-10 flex items-center justify-center mr-3 text-green-500">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </span>
            {t.philosophy}
          </h3>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed italic">
            {t.philosophyText}
          </p>
        </div>
      </div>

      <!-- Right: Why Work With Me (replaces skill bars) -->
      <div>
        <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6 flex items-center">
          <span class="w-10 h-10 flex items-center justify-center mr-3 text-primary">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </span>
          {t.whyMe}
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Reason 1: Affordable -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason1Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason1Text}</p>
          </div>

          <!-- Reason 2: Fast -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason2Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason2Text}</p>
          </div>

          <!-- Reason 3: Local -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason3Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason3Text}</p>
          </div>

          <!-- Reason 4: DSGVO -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason4Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason4Text}</p>
          </div>

          <!-- Reason 5: Mobile -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-teal-100 dark:bg-teal-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason5Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason5Text}</p>
          </div>

          <!-- Reason 6: Support -->
          <div class="group bg-gray-50 dark:bg-gray-800/50 rounded-xl p-5 hover:shadow-lg transition-all duration-300 hover:scale-105">
            <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-white mb-1">{t.reason6Title}</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">{t.reason6Text}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
