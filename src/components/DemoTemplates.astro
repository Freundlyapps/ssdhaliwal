---

<section id="demos" class="py-20 bg-gray-50 dark:bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-10 reveal">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary dark:text-primary-light rounded-full text-sm font-semibold tracking-wide mb-4">
        {labels.tag}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        {labels.title}
      </h2>
      <p class="text-gray-500 dark:text-gray-400 max-w-lg mx-auto">
        {labels.subtitle}
      </p>
    </div>

    <!-- Filter Tabs + Count -->
    <div class="flex items-center justify-between mb-6 reveal">
      <div class="flex gap-2" id="demo-filters">
        <button class="demo-filter active px-4 py-2 text-sm font-semibold rounded-full transition-all bg-primary text-white shadow-sm" data-filter="all">
          {labels.filterAll}
        </button>
        <button class="demo-filter px-4 py-2 text-sm font-semibold rounded-full transition-all bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700" data-filter="websites">
          {labels.filterWebsites}
        </button>
        <button class="demo-filter px-4 py-2 text-sm font-semibold rounded-full transition-all bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700" data-filter="shops">
          {labels.filterShops}
        </button>
        <button class="demo-filter px-4 py-2 text-sm font-semibold rounded-full transition-all bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700" data-filter="ai">
          {labels.filterAI}
        </button>
      </div>
      <span class="text-xs text-gray-400 dark:text-gray-500 hidden sm:block" id="demo-count">
        {demos.length} {labels.count}
      </span>
    </div>

    <!-- Carousel Wrapper -->
    <div class="relative reveal">
      <!-- Scroll arrows -->
      <button
        class="demo-arrow demo-arrow-left absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 z-10 w-10 h-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full shadow-lg flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white hover:border-primary transition-all hidden"
        aria-label="Scroll left"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button
        class="demo-arrow demo-arrow-right absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 z-10 w-10 h-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full shadow-lg flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white hover:border-primary transition-all"
        aria-label="Scroll right"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>

      <!-- Fade edges -->
      <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-gray-50 dark:from-[#0a0a0a] to-transparent z-[5] opacity-0 demo-fade-left"></div>
      <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-gray-50 dark:from-[#0a0a0a] to-transparent z-[5] demo-fade-right"></div>

      <!-- Scrollable track -->
      <div class="demo-track flex gap-4 overflow-x-auto pb-4 scroll-smooth" id="demo-track" style="scrollbar-width:none;-ms-overflow-style:none;">
        {demos.map((demo) => (
          <a
            href={demo.ready ? demo.url : undefined}
            target={demo.ready ? '_blank' : undefined}
            rel={demo.ready ? 'noopener noreferrer' : undefined}
            class:list={[
              'demo-card group flex-shrink-0 w-[220px] rounded-xl border transition-all duration-300',
              demo.ready
                ? `bg-white dark:bg-gray-800/60 border-gray-200/60 dark:border-gray-700/40 hover:border-primary/40 hover:shadow-lg hover:-translate-y-1 cursor-pointer`
                : 'bg-gray-100/50 dark:bg-gray-800/20 border-gray-200/30 dark:border-gray-700/20 opacity-50 cursor-default',
            ]}
            data-category={demo.category}
          >
            <div class="p-5">
              <!-- Icon + Status -->
              <div class="flex items-center justify-between mb-3">
                <div class:list={['w-10 h-10 rounded-lg flex items-center justify-center text-xl', demo.ready ? demo.bgAccent : 'bg-gray-200/50 dark:bg-gray-700/30']}>
                  <span set:html={demo.icon} />
                </div>
                {demo.ready ? (
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider text-green-600 dark:text-green-400 bg-green-500/10">
                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                    Live
                  </span>
                ) : (
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500 bg-gray-200/50 dark:bg-gray-700/30">
                    {labels.comingSoon}
                  </span>
                )}
              </div>

              <!-- Info -->
              <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-0.5 truncate group-hover:text-primary transition-colors">
                {demo.name[lang]}
              </h3>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-3 truncate">
                {demo.business[lang]}
              </p>

              <!-- Price + Action -->
              <div class="flex items-center justify-between">
                <span class={`text-xs font-bold ${demo.ready ? demo.textColor : 'text-gray-400'}`}>
                  {labels.startingFrom} €{demo.price}
                </span>
                {demo.ready && (
                  <span class="text-[11px] font-semibold text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                    {labels.viewDemo} &rarr;
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-10 text-center reveal">
      <p class="text-gray-500 dark:text-gray-400 mb-4">{labels.cta}</p>
      <a
        href={contactHref}
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary hover:bg-blue-700 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all"
      >
        {labels.ctaBtn}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .demo-track::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var track = document.getElementById('demo-track');
  var cards = track ? Array.from(track.querySelectorAll('.demo-card')) : [];
  var leftBtn = document.querySelector('.demo-arrow-left');
  var rightBtn = document.querySelector('.demo-arrow-right');
  var fadeLeft = document.querySelector('.demo-fade-left');
  var fadeRight = document.querySelector('.demo-fade-right');
  var filters = document.querySelectorAll('.demo-filter');
  var countEl = document.getElementById('demo-count');
  var countLabel = countEl ? countEl.textContent.replace(/\d+/, '').trim() : 'demos';

  function updateArrows() {
    if (!track) return;
    var sl = track.scrollLeft;
    var maxScroll = track.scrollWidth - track.clientWidth;
    leftBtn.classList.toggle('hidden', sl < 10);
    fadeLeft.style.opacity = sl < 10 ? '0' : '1';
    rightBtn.classList.toggle('hidden', sl > maxScroll - 10);
    fadeRight.style.opacity = sl > maxScroll - 10 ? '0' : '1';
  }

  if (track) {
    track.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);
    updateArrows();
  }

  if (leftBtn) leftBtn.addEventListener('click', function() {
    track.scrollBy({ left: -240, behavior: 'smooth' });
  });
  if (rightBtn) rightBtn.addEventListener('click', function() {
    track.scrollBy({ left: 240, behavior: 'smooth' });
  });

  // Filters
  filters.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filters.forEach(function(b) {
        b.classList.remove('active', 'bg-primary', 'text-white', 'shadow-sm');
        b.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-500', 'dark:text-gray-400');
      });
      btn.classList.add('active', 'bg-primary', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-500', 'dark:text-gray-400');

      var filter = btn.dataset.filter;
      var visibleCount = 0;

      cards.forEach(function(card) {
        var cat = card.dataset.category;
        if (filter === 'all' || cat === filter) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (countEl) countEl.textContent = visibleCount + ' ' + countLabel;
      track.scrollTo({ left: 0, behavior: 'smooth' });
      setTimeout(updateArrows, 350);
    });
  });
});
</script>
